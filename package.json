{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3001 --turbopack",
    "build": "npm run quality && next build && node build-banner.js",
    "start": "next start --port 3001",
    "quality": "npm run lint:ts && npm run lint:scss",
    "quality:fix": "npm run lint:ts:fix && npm run lint:scss:fix",
    "lint:ts": "next lint",
    "lint:ts:fix": "eslint \"**/*.{ts,tsx}\" --fix",
    "lint:scss": "stylelint \"**/*.scss\"",
    "lint:scss:fix": "stylelint \"**/*.scss\" --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "^15.5.12",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sass": "1.85.0"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.5.2",
    "@romashka_rv/frontend-config": "3.0.2",
    "@svgr/webpack": "8.1.0",
    "@types/node": "22.7.5",
    "@types/react": "19.0.3",
    "@types/react-dom": "19.0.2",
    "eslint": "9.34.0",
    "husky": "9.1.7",
    "chalk": "^5.6.2",
    "figlet": "^1.11.0",
    "lint-staged": "15.3.0",
    "react-html-props": "2.0.3",
    "string-replace-loader": "3.1.0",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "stylelint": {
    "extends": "./node_modules/@romashka_rv/frontend-config/stylelintrc.json"
  },
  "prettier": {
    "extends": "./node_modules/@romashka_rv/frontend-config/prettier.json"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": "npm run lint:ts:fix",
    "**/*.scss": "npm run lint:scss:fix"
  }
}
